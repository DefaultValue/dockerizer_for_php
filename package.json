{
  "private": true,
  "scripts": {
    "prepare": "husky"
  },
  "lint-staged": {
    "*.md": [
      "markdownlint-cli2 --fix",
      "prettier --write"
    ],
    "*.php": [
      "vendor/bin/phpcs",
      "vendor/bin/phpstan analyse --no-progress"
    ]
  },
  "devDependencies": {
    "husky": "~9.1.0",
    "lint-staged": "~15.5.0",
    "markdownlint-cli2": "~0.17.0",
    "prettier": "~3.8.0"
  }
}
