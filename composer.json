{
    "name": "defaultvalue/dockerizer_for_php",
    "description": "Docker-based development for PHP projects with transparent Docker configurations.",
    "version": "3.3.2",
    "type": "project",
    "authors": [{
        "name": "Maksym Zaporozhets",
        "email": "maksimzaporozhets@gmail.com",
        "homepage": "https://www.linkedin.com/in/maksym-zaporozhets-78890789/",
        "role": "VP of Technology"
    }],
    "homepage": "https://github.com/DefaultValue/dockerizer_for_php",
    "readme": "https://github.com/DefaultValue/dockerizer_for_php/wiki",
    "require": {
        "php": "~8.2.0|~8.3.0|~8.4.0|~8.5.0",
        "ext-curl": "*",
        "ext-json": "*",
        "ext-pcntl": "*",
        "ext-posix": "*",
        "ext-simplexml": "*",
        "ext-fileinfo": "*",
        "ext-zip": "*",
        "symfony/config": "~7.4.0",
        "symfony/console": "~7.4.0",
        "symfony/dotenv": "~7.4.0",
        "symfony/yaml": "~7.4.0",
        "symfony/dependency-injection": "~7.4.0",
        "symfony/finder": "~7.4.0",
        "symfony/filesystem": "~7.4.0",
        "symfony/process": "~7.4.0",
        "composer/semver": "~3.4.0",
        "symfony/http-client": "~7.4.0",
        "monolog/monolog": "~3.10.0",
        "aws/aws-sdk-php": "~3.376.0",
        "yosymfony/toml": "~1.0.0"
    },
    "require-dev": {
        "roave/security-advisories": "dev-latest",
        "squizlabs/php_codesniffer": "~3.13.0",
        "phpstan/phpstan": "~2.1.0"
    },
    "autoload": {
        "psr-4": {
            "DefaultValue\\Dockerizer\\": "src/"
        }
    },
    "minimum-stability": "stable",
    "config": {
        "platform": {
            "php": "8.2.0"
        }
    }
}
